---
import { Image } from 'astro:assets';
import { RATING_DISPLAY, CATEGORIES } from '../lib/taxonomy';
import { priceBand, type Restaurant } from '../lib/restaurants';

interface Props {
  restaurant: Restaurant;
}
const { restaurant: r } = Astro.props;
const rating = RATING_DISPLAY[r.data.rating];
const band = priceBand(r.data.price_per_pax);
---

<a
  href={`/restaurant/${r.id}`}
  class="block rounded-xl border border-stone-200 bg-white p-4 transition hover:border-stone-300 hover:shadow-sm"
>
  {
    r.data.cover && (
      <Image src={r.data.cover} alt={r.data.name} width={640} height={360} class="mb-3 h-40 w-full rounded-lg object-cover" />
    )
  }
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-semibold leading-snug">{r.data.name}</h3>
    <span title={rating.label} class="shrink-0 text-lg">{rating.emoji}</span>
  </div>
  <p class="mt-1 text-sm text-stone-500">
    {r.data.area && <span>{r.data.area}</span>}
    {r.data.country !== 'Singapore' && <span> · {r.data.country}</span>}
    {band && <span> · {band}</span>}
    {r.data.is_hawker && <span> · 🏪 hawker</span>}
  </p>
  {
    r.data.categories.length > 0 && (
      <p class="mt-2 text-sm">{r.data.categories.map((c) => CATEGORIES[c].emoji).join(' ')}</p>
    )
  }
</a>
