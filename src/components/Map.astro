---
// Leaflet island. Loads /search/geo.json (also used by proximity search) and
// renders rating-colored circle markers with popups. Client-only by nature.
interface Props {
  height?: string;
}
const { height = 'h-[60vh] sm:h-[420px]' } = Astro.props;
---

<div id="map" class:list={['w-full rounded-xl border border-stone-200 z-0', height]}></div>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import 'leaflet.markercluster';
  import 'leaflet.markercluster/dist/MarkerCluster.css';
  import 'leaflet.markercluster/dist/MarkerCluster.Default.css';

  type GeoItem = {
    slug: string;
    name: string;
    lat: number;
    lng: number;
    rating: 'highly_recommend' | 'recommend';
    categories: string[];
    area: string | null;
    price: number | null;
    hawker: boolean;
  };

  const map = L.map('map', { scrollWheelZoom: false }).setView([1.3521, 103.8198], 12);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 19,
  }).addTo(map);

  const cluster = (L as any).markerClusterGroup({ maxClusterRadius: 40 });

  fetch('/search/geo.json')
    .then((r) => r.json())
    .then((items: GeoItem[]) => {
      for (const it of items) {
        const gold = it.rating === 'highly_recommend';
        const marker = L.circleMarker([it.lat, it.lng], {
          radius: gold ? 9 : 7,
          color: gold ? '#b45309' : '#1d4ed8',
          fillColor: gold ? '#f59e0b' : '#3b82f6',
          fillOpacity: 0.85,
          weight: 2,
        });
        marker.bindPopup(
          `<strong><a href="/restaurant/${it.slug}">${it.name}</a></strong><br>` +
            `${gold ? '⭐ Highly recommend' : '👍 Recommend'}${it.hawker ? ' · 🏪 hawker' : ''}<br>` +
            `${it.area ?? ''}${it.price ? ` · ~$${it.price}/pax` : ''}`
        );
        cluster.addLayer(marker);
      }
      map.addLayer(cluster);
    });

  // "Find me" control (v2 parity): pan to device location
  const FindMe = L.Control.extend({
    options: { position: 'topleft' },
    onAdd() {
      const btn = L.DomUtil.create('a', 'leaflet-bar');
      btn.innerHTML = '📍';
      btn.href = '#';
      btn.title = 'Find me';
      btn.style.cssText = 'width:30px;height:30px;line-height:30px;text-align:center;background:#fff;display:block;font-size:16px;';
      L.DomEvent.on(btn, 'click', (e) => {
        L.DomEvent.preventDefault(e);
        navigator.geolocation?.getCurrentPosition((pos) => {
          const here: [number, number] = [pos.coords.latitude, pos.coords.longitude];
          L.circleMarker(here, { radius: 8, color: '#dc2626', fillColor: '#ef4444', fillOpacity: 0.9 })
            .addTo(map)
            .bindPopup('You are here');
          map.setView(here, 15);
        });
      });
      return btn;
    },
  });
  map.addControl(new FindMe());
</script>
